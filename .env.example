# Server
PORT=3000
NODE_ENV=development

# Shared secret for n8n-facing routes
# Generate with: openssl rand -hex 32
N8N_SHARED_SECRET=replace-with-strong-random-secret

# Credentials for the dashboard login form
DASHBOARD_USER=sabeen
DASHBOARD_PASSWORD=replace-with-strong-password

# Secret used to sign session cookies — must be long and random
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-strong-random-secret

# n8n
N8N_FLOW_2_WEBHOOK_URL=https://n8n.yourinstance.com/webhook/content-generation

# Database
DB_PATH=./data/content-bot.db

# CORS — comma-separated list of allowed origins.
# Dev: Vite default is http://localhost:5173
# Prod: your dashboard URL, e.g. https://contentbot.devspot.app
CORS_ORIGINS=http://localhost:5173
